{
  "$schema": "https://schema.tauri.app/config/2",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../renderer"
  },
  "productName": "Noteslip",
  "version": "26.0.2",
  "identifier": "com.noteslip.daily",
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Noteslip",
        "url": "index.html",
        "width": 1100,
        "height": 750
      }
    ]
  },
  "bundle": {
    "active": true,
    "category": "productivity",
    "icon": ["icons/icon.png"],
    "targets": ["deb", "appimage", "nsis", "msi"],
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["English", "SimpChinese"]
      }
    }
  }
}
